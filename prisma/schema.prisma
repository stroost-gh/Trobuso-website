generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model WebsiteContent {
  id        String   @id @default(cuid())
  sectie    String   @unique
  inhoud    String   // JSON blob met alle teksten
  updatedAt DateTime @updatedAt
}
